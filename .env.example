# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it's in .gitignore.

# Required for all three projects (main.py, truth_committee.py, TruthComitteeBot.py).
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-real-key

# Required only for TruthComitteeBot.py (the Telegram bot).
# Get a token from @BotFather on Telegram.
TELEGRAM_TOKEN=123456789:replace-with-your-real-token
